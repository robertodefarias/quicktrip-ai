<div class="container mt-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>My Travel Itineraries</h1>
    <%= link_to "New Trip", root_path, class: "btn btn-primary" %>
  </div>

  <div class="row">
    <% @chats.each do |chat| %>
      <div class="col-md-4 mb-4">
        <div class="card h-100 shadow-sm">
          <div class="card-body">
            <h5 class="card-title text-primary"><%= chat.trip.city %></h5>

            <p class="card-text">
              <% if chat.trip.content.present? %>
                <%# Mostra apenas o começo do roteiro para não quebrar o layout %>
                <%= truncate(chat.trip.content, length: 120) %>
              <% else %>
                <span class="text-muted">Itinerary being generated...</span>
              <% end %>
            </p>

            <div class="d-flex justify-content-between mt-auto">
              <%= link_to "View Details", chat_path(chat), class: "btn btn-outline-primary btn-sm" %>
              <%= button_to "Delete", chat_path(chat), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-link text-danger p-0" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
