<div class="container py-5">
 <div id="messages">
  <% @chat.messages.each do |message| %>

    <% if message.role == "user" %>
      <div class="text-end mb-3">
        <div class="bg-white p-3 rounded-4 shadow-sm d-inline-block text-start" style="max-width: 80%;">
          <%= simple_format(message.content) %>
        </div>
      </div>

    <% else %>
      <div class="text-start mb-3">
        <div class="bg-white border p-3 rounded-4 shadow-sm d-inline-block" style="max-width: 80%;">
           <%= simple_format(message.content) %>
        </div>
      </div>

    <% end %>

  <% end %>
 </div>

  <%= simple_form_for [@chat, @message] do |f| %>
  <%= f.input :content, label: "Pergunte sobre sua viagem", required: true, input_html: { class: "bg-white rounded-3 shadow-sm" } %>
  <%= f.button :submit, "Pergunte a IA", class: "btn btn-primary" %>
  <% end %>
</div>
