<div class="container py-5">

  <%= turbo_stream_from @chat %>

  <div id="messages" data-controller="chat-scroll" class="mb-4">
    <%= render @chat.messages %>
  </div>

  <turbo-frame id="new_message_container" class="mt-4">
    <%= render "messages/form", chat: @chat, message: @message %>
  </turbo-frame>

</div>
