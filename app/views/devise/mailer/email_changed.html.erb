<p>Olá <%= @email %>!</p>

<% if @resource.try(:unconfirmed_email?) %>
  <p>Estamos entrando em contato para informar que o seu e-mail está sendo alterado para: <%= @resource.unconfirmed_email %>.</p>
<% else %>
  <p>Estamos entrando em contato para informar que o seu e-mail está sendo alterado para: <%= @resource.email %>.</p>
<% end %>
