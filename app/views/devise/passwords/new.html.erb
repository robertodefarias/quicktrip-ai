<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-6 col-lg-5">
      <div class="card shadow-sm border-0 rounded-4 p-4">
        <h2 class="text-center mb-4 fw-bold">Esqueceu sua senha?</h2>
        <p class="text-center text-muted mb-4">Insira seu e-mail para receber as instruções de recuperação.</p>

        <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
          <%= f.error_notification %>

          <div class="form-inputs">
            <%= f.input :email,
                        label: "E-mail",
                        required: true,
                        autofocus: true,
                        input_html: { class: "bg-white rounded-3 shadow-sm", autocomplete: "email" } %>
          </div>

          <div class="form-actions mt-4">
            <%= f.button :submit, "Enviar instruções", class: "btn btn-primary w-100 rounded-3" %>
          </div>
        <% end %>

        <div class="text-center mt-4">
          <%= render "devise/shared/links" %>
        </div>
      </div>
    </div>
  </div>
</div>
