<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-6 col-lg-5">
      <div class="card shadow-sm border-0 rounded-4 p-4">
        <h2 class="text-center mb-4 fw-bold">Crie sua conta</h2>
        <p class="text-center text-muted mb-4">Comece a gerar roteiros rápidos com IA agora mesmo.</p>

        <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
          <%= f.input :email,
            label: "E-mail",
            required: true,
            autofocus: true,
            input_html: { autocomplete: "email" } %>

          <%= f.input :password,
            label: "Senha",
            required: true,
            input_html: { autocomplete: "new-password" } %>

          <%= f.input :password_confirmation,
            label: "Confirme sua senha",
            required: true,
            input_html: { autocomplete: "new-password" } %>

          <%= f.button :submit, "Criar conta", class: "btn btn-primary w-100 rounded-3" %>
        <% end %>

        <div class="text-center mt-4">
          <%= render "devise/shared/links" %>
        </div>
      </div>
    </div>
  </div>
</div>
